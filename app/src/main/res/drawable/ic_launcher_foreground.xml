<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimalistische Blüte als App-Icon: acht Blütenblätter (Wellness/Dehnung/Ruhe),
  weiß auf dem salbeigrünen Hintergrund, mit einem Terracotta-Kern als Akzent.
  Alle Formen liegen innerhalb der sicheren Zone (Kreis mit r=30 um den Mittelpunkt),
  damit auf jedem Launcher (rund, eckig, Squircle ...) nichts abgeschnitten wird.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ein Blütenblatt (vertikale Ellipse), wird unten 8x rotiert -->
    <group android:name="petal_0" android:pivotX="54" android:pivotY="54" android:rotation="0">
        <path android:fillColor="#FFFFFF" android:pathData="M48,42 A6,14 0 1,0 60,42 A6,14 0 1,0 48,42 Z" />
    </group>
    <group android:name="petal_45" android:pivotX="54" android:pivotY="54" android:rotation="45">
